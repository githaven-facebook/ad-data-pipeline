[flake8]
max-line-length = 120
extend-ignore =
    # Line break before binary operator (black compatible)
    W503,
    # Line break after binary operator
    W504,
    # Whitespace before ':'
    E203,
    # Line too long (handled by black)
    E501,
    # Missing whitespace around operator (false positives with type hints)
    E225,
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .mypy_cache,
    .pytest_cache,
    logs,
    airflow.db
per-file-ignores =
    # Allow unused imports in __init__.py for re-exports
    __init__.py:F401
    # Allow assert statements in tests
    tests/*:S101
max-complexity = 12
